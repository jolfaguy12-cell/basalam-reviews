APP_ENV=development

# WordPress plugin
WORDPRESS_ENDPOINT=https://dev.behdashtik.ir
WORDPRESS_API_KEY=
WORDPRESS_PLUGIN_SECRET=

# Data Hub
DATA_HUB_ENDPOINT=
DATA_HUB_API_KEY=

# Basalam
BASALAM_ENDPOINT=https://services.basalam.com
BASALAM_VENDOR_ID=1399163
