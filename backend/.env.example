# ─────────────────────────────────────────────────────────────────────────────
# Basalam Review Backend — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
# APP_ENV selects the active credential set and file paths:
#
#   dev        → DEV_WORDPRESS_* credentials
#                data/reviews_dev.db  |  data/debug_dev.log  |  data/plugin_dev.log
#
#   production → PROD_WORDPRESS_* credentials
#                data/reviews_prod.db |  data/debug_prod.log |  data/plugin_prod.log
#
# Database and log paths are derived automatically — do NOT set them manually.
# Switching environments requires only changing APP_ENV and restarting.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=dev

# ─── Dev WordPress credentials ───────────────────────────────────────────────
# Install the plugin on your dev WordPress site, configure keys there,
# then paste them here.
DEV_WORDPRESS_ENDPOINT=https://dev.example.com
DEV_WORDPRESS_API_KEY=<paste from plugin settings on dev site>
DEV_WORDPRESS_PLUGIN_SECRET=<paste from plugin settings on dev site>

# ─── Production WordPress credentials ────────────────────────────────────────
# Active only when APP_ENV=production.
PROD_WORDPRESS_ENDPOINT=https://yourdomain.com
PROD_WORDPRESS_API_KEY=<paste from plugin settings on production site>
PROD_WORDPRESS_PLUGIN_SECRET=<paste from plugin settings on production site>

# ─── Data Hub HTTP API (shared — same for dev and production) ────────────────
DATA_HUB_ENDPOINT=https://mainhub.behdashtik.ir
DATA_HUB_API_KEY=<your datahub api key>

# ─── Basalam (shared) ────────────────────────────────────────────────────────
BASALAM_ENDPOINT=https://services.basalam.com
BASALAM_VENDOR_ID=1399163
BASALAM_VENDOR_IDENTIFIER=behdashtik

# ─── Service ─────────────────────────────────────────────────────────────────
SERVICE_PORT=8100
CRAWL_PAGE_LIMIT=20
CRAWL_DELAY_SECONDS=2.0
SYNC_INTERVAL_MINUTES=360
CRAWL_INTERVAL_HOURS=24         # Min hours between Basalam crawls (0 = always crawl)
BLOCK_STAR_ONLY_REVIEWS=false   # true = skip star-only reviews before pushing to WordPress

# ─── Log Server ──────────────────────────────────────────────────────────────
# Optionally proxy via nginx: https://hub.behdashtik.ir/brp → localhost:8101
LOG_SERVER_PORT=8101
